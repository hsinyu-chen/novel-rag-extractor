# Weaviate Configuration
WEAVIATE_HOST=weaviate.dynameis.app
WEAVIATE_HTTP_PORT=443
WEAVIATE_HTTP_SECURE=True
WEAVIATE_GRPC_PORT=50051
WEAVIATE_GRPC_SECURE=False

# 1. Embedding Model (Microsoft Multilingual E5 - FP16 for precision)
EMBED_MODEL_REPO=phate334/multilingual-e5-large-gguf
EMBED_MODEL_FILE=multilingual-e5-large-f16.gguf
EMBED_N_CTX=512

# 2. Summary/LLM Model (Google Gemma-4 E4B)
SUMMARY_MODEL_REPO=unsloth/gemma-4-E4B-it-GGUF
SUMMARY_MODEL_FILE=gemma-4-E4B-it-Q4_K_M.gguf
SUMMARY_TEMP=1.0
SUMMARY_TOP_P=0.95
SUMMARY_TOP_K=64

# Global Model Parameters
N_GPU_LAYERS=-1
N_CTX=32768
