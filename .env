# Weaviate Configuration
WEAVIATE_HOST=weaviate.dynameis.app
WEAVIATE_HTTP_PORT=443
WEAVIATE_HTTP_SECURE=True
WEAVIATE_GRPC_PORT=50051
WEAVIATE_GRPC_SECURE=False

# LLM Server (Gemma-4)
SUMMARY_BASE_URL=http://127.0.0.1:8080/v1
SUMMARY_API_KEY=no-key-required
SUMMARY_MODEL=gemma-4-E4B-it-Q4_K_M
SUMMARY_TEMP=1.0
SUMMARY_TOP_P=0.95
SUMMARY_TOP_K=64

# QA Agent Sampling
QA_TEMP=1.0
QA_TOP_P=0.95
QA_TOP_K=64

# Embedding Server (multilingual-e5-large)
EMBED_BASE_URL=http://127.0.0.1:8081/v1
EMBED_API_KEY=no-key-required
EMBED_MODEL=multilingual-e5-large-f16

